Options -Indexes

# Activer mod_rewrite
RewriteEngine On

# Propager le header Authorization jusqu'a PHP (Apache + mod_rewrite)
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# Forcer les requêtes OPTIONS (preflight CORS) vers index.php AVANT toute autre règle
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule .* index.php [L]

# Rediriger toutes les autres requêtes vers index.php (front controller)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
